{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/booking-system/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/signup(/.*)?",
      "dest": "/api/signup/index.php"
    },
    {
      "src": "/admin(/.*)?",
      "dest": "/api/admin/index.php"
    },
    {
      "src": "/member(/.*)?",
      "dest": "/api/member/index.php"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1",
      "headers": {
        "content-type": "text/css"
      }
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1",
      "headers": {
        "content-type": "application/javascript"
      }
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/images/favicon.ico"
    },
    {
      "src": "/(.*)\\.css$",
      "dest": "/css/$1.css",
      "headers": {
        "content-type": "text/css"
      }
    },
    {
      "src": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico)$",
      "dest": "/images/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}